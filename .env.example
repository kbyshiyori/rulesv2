# Copy to .env for local builds (.env is gitignored). In CI these are GitHub Secrets,
# NOT committed. See README.md > Secrets.

# 境外 DNS. NextDNS "DNS-over-HTTPS" URL from your NextDNS setup page.
# Embeds your config id -> treat as a secret. Leave empty to keep the upstream dns-server.
NEXTDNS_DOH_URL=

# yyz delivery (rsync over SSH). Deploy is skipped unless KEY + HOST + DEST are set.
YYZ_SSH_KEY=
YYZ_SSH_HOST=
YYZ_SSH_USER=
YYZ_KNOWN_HOSTS=          # optional; `ssh-keyscan <YYZ_SSH_HOST>` output. Empty = accept-new
YYZ_DEST=                 # full remote file path, e.g. /srv/rulesv2/<rand>/backcn.conf
